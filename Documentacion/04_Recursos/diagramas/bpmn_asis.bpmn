<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_ASIS" targetNamespace="http://inflesusventas/bpmn">
  <bpmn:collaboration id="Collab_ASIS">
    <bpmn:participant id="Part_ASIS" name="InfleSusVentas - Cotizacion Manual (AS-IS)" processRef="Proc_ASIS"/>
  </bpmn:collaboration>
  <bpmn:process id="Proc_ASIS" isExecutable="false">
    <bpmn:laneSet id="LaneSet_ASIS">
      <bpmn:lane id="Lane_Cliente" name="Cliente">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Recibe_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Resp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gw_Acep</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Win</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Gerente" name="Gerente">
        <bpmn:flowNodeRef>T_Revisa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Cotiza</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Calcula</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Envia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Seg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Neg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Lose</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Solicitud recibida (WhatsApp / Correo / Web)">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Revisa" name="Revisa la solicitud manualmente">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Cotiza" name="Cotiza usando una plantilla">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Calcula" name="Calcula precio e IGV a mano">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Envia" name="Genera y envia el PDF (correo o WhatsApp)">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Recibe_1" name="Recibe la cotizacion en PDF">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Resp" name="Responde?">
      <bpmn:incoming>F6</bpmn:incoming>
      <bpmn:incoming>F8</bpmn:incoming>
      <bpmn:outgoing>F7</bpmn:outgoing>
      <bpmn:outgoing>F9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Seg" name="Da seguimiento manual: reitera por WhatsApp e insiste">
      <bpmn:incoming>F7</bpmn:incoming>
      <bpmn:outgoing>F8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gw_Acep" name="Acepta?">
      <bpmn:incoming>F9</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
      <bpmn:outgoing>F11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Win" name="Venta cerrada">
      <bpmn:incoming>F10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="T_Neg" name="Negocia: ofrece descuento (max 10%) o ajusta condiciones">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:outgoing>F12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Lose" name="Venta perdida">
      <bpmn:incoming>F12</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start_1" targetRef="T_Revisa"/>
    <bpmn:sequenceFlow id="F2" sourceRef="T_Revisa" targetRef="T_Cotiza"/>
    <bpmn:sequenceFlow id="F3" sourceRef="T_Cotiza" targetRef="T_Calcula"/>
    <bpmn:sequenceFlow id="F4" sourceRef="T_Calcula" targetRef="T_Envia"/>
    <bpmn:sequenceFlow id="F5" sourceRef="T_Envia" targetRef="Recibe_1"/>
    <bpmn:sequenceFlow id="F6" sourceRef="Recibe_1" targetRef="Gw_Resp"/>
    <bpmn:sequenceFlow id="F7" name="No" sourceRef="Gw_Resp" targetRef="T_Seg"/>
    <bpmn:sequenceFlow id="F8" name="reintenta" sourceRef="T_Seg" targetRef="Gw_Resp"/>
    <bpmn:sequenceFlow id="F9" name="Si" sourceRef="Gw_Resp" targetRef="Gw_Acep"/>
    <bpmn:sequenceFlow id="F10" name="Acepta" sourceRef="Gw_Acep" targetRef="End_Win"/>
    <bpmn:sequenceFlow id="F11" name="No acepta" sourceRef="Gw_Acep" targetRef="T_Neg"/>
    <bpmn:sequenceFlow id="F12" name="Sin acuerdo" sourceRef="T_Neg" targetRef="End_Lose"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Di_ASIS">
    <bpmndi:BPMNPlane id="Plane_ASIS" bpmnElement="Collab_ASIS">
      <bpmndi:BPMNShape id="Sh_Part" bpmnElement="Part_ASIS" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1520" height="320"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_LaneCliente" bpmnElement="Lane_Cliente" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1490" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_LaneGerente" bpmnElement="Lane_Gerente" isHorizontal="true">
        <dc:Bounds x="190" y="200" width="1490" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_Start_1" bpmnElement="Start_1">
        <dc:Bounds x="220" y="122" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_Recibe_1" bpmnElement="Recibe_1">
        <dc:Bounds x="740" y="110" width="110" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_Gw_Resp" bpmnElement="Gw_Resp" isMarkerVisible="true">
        <dc:Bounds x="900" y="115" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_Gw_Acep" bpmnElement="Gw_Acep" isMarkerVisible="true">
        <dc:Bounds x="1180" y="115" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_End_Win" bpmnElement="End_Win">
        <dc:Bounds x="1420" y="122" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_T_Revisa" bpmnElement="T_Revisa">
        <dc:Bounds x="300" y="290" width="110" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_T_Cotiza" bpmnElement="T_Cotiza">
        <dc:Bounds x="440" y="290" width="110" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_T_Calcula" bpmnElement="T_Calcula">
        <dc:Bounds x="580" y="290" width="110" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_T_Envia" bpmnElement="T_Envia">
        <dc:Bounds x="720" y="290" width="110" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_T_Seg" bpmnElement="T_Seg">
        <dc:Bounds x="980" y="290" width="140" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_T_Neg" bpmnElement="T_Neg">
        <dc:Bounds x="1270" y="290" width="150" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sh_End_Lose" bpmnElement="End_Lose">
        <dc:Bounds x="1440" y="300" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1">
        <di:waypoint x="256" y="140"/><di:waypoint x="355" y="290"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2">
        <di:waypoint x="410" y="320"/><di:waypoint x="440" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3">
        <di:waypoint x="550" y="320"/><di:waypoint x="580" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4">
        <di:waypoint x="690" y="320"/><di:waypoint x="720" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5">
        <di:waypoint x="775" y="290"/><di:waypoint x="795" y="170"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F6" bpmnElement="F6">
        <di:waypoint x="850" y="140"/><di:waypoint x="900" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F7" bpmnElement="F7">
        <di:waypoint x="925" y="165"/><di:waypoint x="1010" y="290"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F8" bpmnElement="F8">
        <di:waypoint x="1050" y="290"/><di:waypoint x="940" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F9" bpmnElement="F9">
        <di:waypoint x="950" y="140"/><di:waypoint x="1180" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F10" bpmnElement="F10">
        <di:waypoint x="1230" y="140"/><di:waypoint x="1420" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F11" bpmnElement="F11">
        <di:waypoint x="1205" y="165"/><di:waypoint x="1320" y="290"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F12" bpmnElement="F12">
        <di:waypoint x="1420" y="320"/><di:waypoint x="1458" y="318"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
