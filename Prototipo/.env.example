# ============================================================================
#  InfleSusVentas — variables de entorno
#  Copia este archivo como  .env  y completa los valores. (.env está en .gitignore)
#  Se cargan automáticamente al ejecutar  npm start  /  npm run dev.
# ============================================================================

# --- Envío de correo por SMTP (CU-07) -----------------------------------
# Si NO configuras estas variables, el sistema funciona en "modo simulado"
# (registra el envío en consola sin enviar realmente).
#
# Gmail: activa la verificación en 2 pasos y crea una "Contraseña de aplicación"
#        (16 caracteres) en https://myaccount.google.com/apppasswords
#        Host smtp.gmail.com · Puerto 465 (SSL) o 587 (STARTTLS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_FROM=InfleSusVentas <tucorreo@gmail.com>

# --- Validación de RUC con apis.net.pe / SUNAT (CU-02) ------------------
# Regístrate en https://apis.net.pe y copia tu token del panel de usuario.
# Sin token, el sistema usa un padrón local de demostración.
APIS_NET_TOKEN=
# Opcional. Por defecto usa el endpoint v2. Descomenta para usar otro:
# APIS_NET_URL=https://api.apis.net.pe/v2/sunat/ruc
