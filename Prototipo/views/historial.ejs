<%- include('partials/head', { titulo: 'Historial' }) %>
<%- include('partials/sidebar') %>
  <div class="topbar">
    <h1>Historial de cotizaciones</h1>
    <a class="btn" href="/cotizaciones/nueva">＋ Nueva Cotización</a>
  </div>
  <div class="main">
    <div class="card">
      <form method="get" action="/historial" style="display:flex;gap:8px;max-width:520px;margin-bottom:16px">
        <input type="text" name="q" value="<%= filtro %>" placeholder="Buscar por número, cliente o fecha…">
        <button class="btn oscuro" type="submit">Buscar</button>
        <% if (filtro) { %><a class="btn ghost" href="/historial">Limpiar</a><% } %>
      </form>
      <% if (cotizaciones.length === 0) { %>
        <p class="muted">Sin resultados.</p>
      <% } else { %>
      <div class="tabla">
        <table>
          <thead><tr><th class="center">N°</th><th>Cliente</th><th>Fecha</th><th class="num">Total</th><th class="center">Estado</th><th class="center">Acción</th></tr></thead>
          <tbody>
            <% cotizaciones.forEach(c => { %>
            <tr>
              <td class="center"><b><%= c.numero %></b></td>
              <td><%= c.razon_social || '—' %></td>
              <td><%= c.fecha %></td>
              <td class="num">S/ <%= c.total.toFixed(2) %></td>
              <td class="center"><span class="badge <%= c.estado.replace(' ','') %>"><%= c.estado %></span></td>
              <td class="center"><a class="btn ghost sm" href="/cotizaciones/<%= c.numero %>">Ver</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
<%- include('partials/foot') %>
