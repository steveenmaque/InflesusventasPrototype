<%- include('partials/head', { titulo: 'Nueva Cotización' }) %>
<%- include('partials/sidebar') %>
  <div class="topbar"><h1>Nueva Cotización</h1></div>
  <div class="main">
    <% if (error) { %><div class="alert err"><%= error %></div><% } %>

    <form action="/cotizaciones" method="post" id="formCot">
      <!-- ===== CU-02: Cliente y validación de RUC ===== -->
      <div class="card">
        <h2>Cliente</h2>
        <div class="fila">
          <div>
            <label for="ruc">RUC</label>
            <div style="display:flex;gap:8px">
              <input type="text" id="ruc" name="ruc" maxlength="11" placeholder="11 dígitos" inputmode="numeric">
              <button type="button" class="btn oscuro" id="btnRuc" style="white-space:nowrap">Validar</button>
            </div>
            <div class="hint" id="rucMsg"></div>
          </div>
          <div>
            <label for="razon_social">Razón social <span style="color:var(--error)">*</span></label>
            <input type="text" id="razon_social" name="razon_social" required placeholder="Se autocompleta con un RUC válido (editable)">
          </div>
        </div>
        <div class="fila">
          <div><label for="correo">Correo del cliente</label><input type="email" id="correo" name="correo" placeholder="cliente@correo.com"></div>
          <div><label for="telefono">Teléfono</label><input type="text" id="telefono" name="telefono"></div>
        </div>
      </div>

      <!-- ===== CU-03: Ítems ===== -->
      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <h2 style="margin:0">Ítems de la cotización</h2>
          <button type="button" class="btn ghost sm" id="btnAddItem">＋ Agregar ítem</button>
        </div>
        <p class="hint">Las medidas obligatorias cambian según la categoría (RD-03). En “Globo” el diámetro se deriva de la altura. En “Otros” la descripción es libre.</p>
        <div id="items"></div>
      </div>

      <!-- ===== CU-04 + CU-05: Descuento y desglose ===== -->
      <div class="card">
        <h2>Descuento y totales</h2>
        <div class="fila" style="align-items:end">
          <div style="max-width:220px">
            <label for="descuento_pct">Descuento por cantidad (%)</label>
            <input type="number" id="descuento_pct" name="descuento_pct" value="0" min="0" max="<%= config.tope_descuento %>" step="0.5">
            <div class="hint">Tope <%= config.tope_descuento %>% (RD-08). Un valor mayor se limita automáticamente.</div>
          </div>
        </div>
        <div class="desglose" id="desglose">
          <div class="k">Precio base</div><div class="v" id="d_base">S/ 0.00</div>
          <div class="k">Descuento</div><div class="v" id="d_desc">- S/ 0.00</div>
          <div class="k">Subtotal</div><div class="v" id="d_sub">S/ 0.00</div>
          <div class="k">IGV (<%= config.igv_pct %>%)</div><div class="v" id="d_igv">S/ 0.00</div>
          <div class="k total">TOTAL</div><div class="v total" id="d_total">S/ 0.00</div>
        </div>
      </div>

      <input type="hidden" name="items_json" id="items_json">
      <div class="acciones">
        <button type="submit" class="btn">Guardar cotización</button>
        <a href="/" class="btn ghost">Cancelar</a>
      </div>
    </form>
  </div>

  <script>
    // Metadatos de categorías (medidas obligatorias) provistos por el servidor (RD-03).
    window.CATEGORIAS = <%- JSON.stringify(categorias) %>;
    window.CFG = { igv: <%= config.igv_pct %>, tope: <%= config.tope_descuento %> };
  </script>
  <script src="/js/app.js"></script>
<%- include('partials/foot') %>
