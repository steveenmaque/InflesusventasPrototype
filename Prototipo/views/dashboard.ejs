<%- include('partials/head', { titulo: 'Inicio · InfleSusVentas' }) %>
<%- include('partials/sidebar') %>
  <div class="topbar">
    <h1>Panel principal</h1>
    <a class="btn" href="/cotizaciones/nueva">＋ Nueva Cotización</a>
  </div>
  <div class="main">
    <div class="grid-kpi">
      <div class="kpi"><div class="n"><%= resumen.cantidad %></div><div class="l">Cotizaciones emitidas</div></div>
      <div class="kpi naranja"><div class="n">S/ <%= resumen.monto.toFixed(2) %></div><div class="l">Monto total cotizado</div></div>
      <div class="kpi oscuro"><div class="n"><%= resumen.clientes %></div><div class="l">Clientes registrados</div></div>
    </div>

    <div class="card">
      <h2>Cotizaciones recientes</h2>
      <% if (recientes.length === 0) { %>
        <p class="muted">Aún no hay cotizaciones. Cree la primera con “Nueva Cotización”.</p>
      <% } else { %>
      <table>
        <thead><tr><th>N°</th><th>Cliente</th><th>Fecha</th><th>Total</th><th>Estado</th><th></th></tr></thead>
        <tbody>
          <% recientes.forEach(c => { %>
          <tr>
            <td><b><%= c.numero %></b></td>
            <td><%= c.razon_social || '—' %></td>
            <td><%= c.fecha %></td>
            <td>S/ <%= c.total.toFixed(2) %></td>
            <td><span class="badge <%= c.estado.replace(' ','') %>"><%= c.estado %></span></td>
            <td><a class="btn ghost sm" href="/cotizaciones/<%= c.numero %>">Ver</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
<%- include('partials/foot') %>
