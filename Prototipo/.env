# --- Entrega real por Gmail ---------------------------------------------
#  YA ESTÁ TODO LISTO. Solo falta pegar la App Password en SMTP_PASS:
#    1) Activa la verificación en 2 pasos en tu cuenta Google.
#    2) Crea una "Contraseña de aplicación" en:
#          https://myaccount.google.com/apppasswords
#    3) Pega esas 16 letras en SMTP_PASS (SIN espacios) y reinicia: npm start
#  Nota: la contraseña normal de Google NO sirve; debe ser una App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=inflesusventas6@gmail.com
SMTP_PASS=qnmjdndlrfgxgftk
SMTP_FROM=InfleSusVentas <inflesusventas6@gmail.com>

